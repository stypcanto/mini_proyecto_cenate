# ==========================================================
# 🧹 Docker Ignore para FRONTEND (React + Nginx)
# ==========================================================

# Node y dependencias locales
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-lock.yaml

# Builds locales
/build
/dist
/.next
/.cache

# Archivos de sistema
.DS_Store
Thumbs.db

# Entornos locales (manejar por Docker Compose)
.env*
.env.local
.env.development*
.env.production*

# Control de versiones
.git
.gitignore
.gitattributes

# Configuración de IDEs
.vscode
.idea
*.swp

# Archivos temporales
*.log
*.tmp
*.bak
*.orig